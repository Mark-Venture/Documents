    # --------------------------------------------------------
    # MERGE LOGIC
    # --------------------------------------------------------

    def merge_files(self):
        """
        Merges:
          - Selected sequences (scaled + reversed)
          - Selected subroutines (with conflict resolution)
          - Updated channel calibration values
        Writes the result to a new file chosen by the user.
        """
        if not self.my_file:
            messagebox.showerror("Error", "Please select your settings file.")
            return
        if not self.friend_file:
            messagebox.showerror("Error", "Please select a friend settings file.")
            return

        save_path = filedialog.asksaveasfilename(
            title="Save Merged Settings As",
            defaultextension=".txt",
            filetypes=[("Text Files", "*.txt"), ("All Files", "*.*")]
        )
        if not save_path:
            return

        # Load both files
        my_text = load_file(self.my_file)
        friend_text = load_file(self.friend_file)

        # Build new limits from GUI
        try:
            new_limits, reversed_channels = self.build_new_limits_and_reversed()
        except ValueError as e:
            messagebox.showerror("Error", str(e))
            return

        # Old limits from "my" file
        my_channels = extract_channels(my_text)
        old_limits = {}
        for i, tag in enumerate(my_channels):
            v = parse_channel_values(tag)
            old_limits[i] = (v["min"], v["max"])

        # ----------------------------------------------------
        # MERGE SEQUENCES
        # ----------------------------------------------------
        selected_sequences = []
        for var, seq in zip(self.seq_vars, self.friend_sequences):
            if var.get():
                scaled = scale_sequence(seq, old_limits, new_limits, reversed_channels)
                selected_sequences.append(scaled)

        if selected_sequences and "</Sequences>" in my_text:
            combined = "\n".join(selected_sequences)
            my_text = my_text.replace("</Sequences>", f"{combined}\n</Sequences>")

        # ----------------------------------------------------
        # MERGE SUBROUTINES
        # ----------------------------------------------------
        my_has_script_tag = re.search(r"<Script[^>]*>", my_text) is not None
        my_script = extract_script(my_text) if my_has_script_tag else my_text
        my_subs = extract_subroutines(my_script)
        existing_names = {s["name"] for s in my_subs}

        imported_blocks = []

        for var, sub in zip(self.sub_vars, self.friend_subs):
            if not var.get():
                continue

            name = sub["name"]
            text = sub["text"]

            if name in existing_names:
                action, new_name = self.ask_sub_conflict(name)
                if action == "skip":
                    continue
                elif action == "overwrite":
                    my_script = remove_sub_by_name(my_script, name)
                    existing_names.discard(name)
                elif action == "rename":
                    if not new_name:
                        continue
                    text = re.sub(
                        r'\bsub\s+' + re.escape(name) + r'\b',
                        f"sub {new_name}",
                        text,
                        count=1
                    )
                    name = new_name

            imported_blocks.append(text.strip())
            existing_names.add(name)

        if imported_blocks:
            my_script = my_script.strip()
            my_script = (
                my_script
                + "\n\n# --- Imported Friend Subroutines ---\n"
                + "\n\n".join(imported_blocks)
                + "\n"
            )

            if my_has_script_tag:
                my_text = re.sub(
                    r"<Script[^>]*>.*?</Script>",
                    f"<Script>\n{my_script}\n</Script>",
                    my_text,
                    flags=re.DOTALL
                )
            else:
                my_text = my_script

        # ----------------------------------------------------
        # UPDATE CHANNEL TAGS
        # ----------------------------------------------------
        def update_channel(match):
            idx = update_channel.counter
            update_channel.counter += 1
            tag = match.group(0)

            if idx in new_limits:
                n_min, n_max, n_home, n_neut = new_limits[idx]
                tag = re.sub(r'min="\d+"', f'min="{n_min}"', tag)
                tag = re.sub(r'max="\d+"', f'max="{n_max}"', tag)
                tag = re.sub(r'home="\d+"', f'home="{n_home}"', tag)
                tag = re.sub(r'neutral="\d+"', f'neutral="{n_neut}"', tag)

            return tag

        update_channel.counter = 0
        my_text = re.sub(r'<Channel [^>]*>', update_channel, my_text)

        # ----------------------------------------------------
        # WRITE OUTPUT FILE
        # ----------------------------------------------------
        with open(save_path, "w", encoding="utf-8") as f:
            f.write(my_text)

        messagebox.showinfo("Success", f"Merged file saved:\n{save_path}")

