# ------------------------------------------------------------
# SEQUENCE FRAME PARSING FOR PREVIEW
# ------------------------------------------------------------

def parse_sequence_frames(seq_text):
    """
    Parses a <Sequence> block into:
      - frames: list of dicts {channel: value}
      - delays: list of delay_ms per frame (int)
      - channel_order: list of channels in order of first appearance

    Assumes each <Frame> contains a list of integers interpreted as:
      value0 channel0 value1 channel1 value2 channel2 ...
    """
    frames = []
    delays = []
    channel_order = []

    # Match <Frame ...>values</Frame>
    pattern = r'(<Frame[^>]*>)([^<]+)</Frame>'
    for m in re.finditer(pattern, seq_text, re.DOTALL):
        tag = m.group(1)
        vals_str = m.group(2).strip()
        parts = vals_str.split()
        nums = []
        for p in parts:
            try:
                nums.append(int(p))
            except:
                # Ignore non-integer tokens
                pass

        frame_channels = {}
        # Interpret as value, channel, value, channel, ...
        for i in range(0, len(nums) - 1, 2):
            value = nums[i]
            ch = nums[i + 1]
            frame_channels[ch] = value
            if ch not in channel_order:
                channel_order.append(ch)

        frames.append(frame_channels)

        # Try to get duration/time from tag, else default
        delay = 200  # default ms
        dm = re.search(r'duration="(\d+)"', tag)
        if not dm:
            dm = re.search(r'time="(\d+)"', tag, re.IGNORECASE)
        if dm:
            try:
                delay = int(dm.group(1))
            except:
                pass
        delays.append(delay)

    if not frames:
        return [], [], []

    return frames, delays, channel_order

# ------------------------------------------------------------
# SEQUENCE PREVIEW WINDOW
# ------------------------------------------------------------

class SequencePreviewWindow:
    """
    A Toplevel window that previews a single sequence:

    - Shows only channels used in the sequence
    - Channels ordered by first appearance
    - Horizontal bars scaled using each channel's Min/Max
    - Reversed channels flip bar direction
    - Real-time playback using per-frame delays
    - Play / Pause / Stop / Step
    - Timeline slider (scrub to any frame)
    """

    def __init__(self, parent, seq_name, frames, delays,
                 channel_order, new_limits, reversed_channels):
        self.parent = parent
        self.seq_name = seq_name
        self.frames = frames
        self.delays = delays
        self.channel_order = channel_order
        self.new_limits = new_limits
        self.reversed_channels = set(reversed_channels)

        self.num_frames = len(frames)
        self.current_frame = 0
        self.playing = False
        self.after_id = None

        # Guard flag to prevent slider recursion
        self.slider_updating = False

        # Create window
        self.win = tk.Toplevel(parent)
        self.win.title(f"Preview Sequence: {seq_name}")
        self.win.protocol("WM_DELETE_WINDOW", self.on_close)

        # Title
        top = ttk.Frame(self.win)
        top.pack(fill="x", padx=10, pady=5)
        ttk.Label(top, text=f"Sequence: {seq_name}",
                  font=("Arial", 11, "bold")).pack(anchor="w")

        # Channel bars container
        self.bar_frame = ttk.Frame(self.win)
        self.bar_frame.pack(fill="both", expand=True, padx=10, pady=5)

        self.channel_rows = {}  # ch -> (value_label, canvas)
        self.bar_width = 250
        self.bar_height = 16

        # Header row
        header = ttk.Frame(self.bar_frame)
        header.pack(fill="x")
        ttk.Label(header, text="Ch", width=4).grid(row=0, column=0, padx=2)
        ttk.Label(header, text="Value", width=8).grid(row=0, column=1, padx=2)
        ttk.Label(header, text="Position", width=20).grid(row=0, column=2, padx=2)

        # Rows container
        self.rows_container = ttk.Frame(self.bar_frame)
        self.rows_container.pack(fill="both", expand=True)

        # One row per channel in channel_order
        for r, ch in enumerate(self.channel_order):
            row = ttk.Frame(self.rows_container)
            row.grid(row=r, column=0, sticky="w", pady=2)

            ttk.Label(row, text=str(ch), width=4).pack(side="left", padx=2)

            val_label = ttk.Label(row, text="0", width=8)
            val_label.pack(side="left", padx=2)

            canvas = tk.Canvas(
                row,
                width=self.bar_width,
                height=self.bar_height,
                bg="white",
                highlightthickness=1,
                relief="sunken"
            )
            canvas.pack(side="left", padx=4)

            self.channel_rows[ch] = (val_label, canvas)

        # Playback controls
        ctrl = ttk.Frame(self.win)
        ctrl.pack(fill="x", padx=10, pady=5)

        self.btn_step_back = ttk.Button(ctrl, text="◀", width=3,
                                        command=self.step_back)
        self.btn_play = ttk.Button(ctrl, text="▶", width=3,
                                   command=self.play)
        self.btn_pause = ttk.Button(ctrl, text="❚❚", width=3,
                                    command=self.pause)
        self.btn_stop = ttk.Button(ctrl, text="■", width=3,
                                   command=self.stop)
        self.btn_step_fwd = ttk.Button(ctrl, text="▶", width=3,
                                       command=self.step_forward)

        self.btn_step_back.pack(side="left", padx=2)
        self.btn_play.pack(side="left", padx=2)
        self.btn_pause.pack(side="left", padx=2)
        self.btn_stop.pack(side="left", padx=2)
        self.btn_step_fwd.pack(side="left", padx=2)

        self.lbl_status = ttk.Label(
            ctrl,
            text=f"Frame: 1 / {self.num_frames}"
        )
        self.lbl_status.pack(side="right", padx=5)

        # Timeline slider
        slider_frame = ttk.Frame(self.win)
        slider_frame.pack(fill="x", padx=10, pady=5)

        self.slider = ttk.Scale(
            slider_frame,
            from_=0,
            to=max(self.num_frames - 1, 0),
            orient="horizontal",
            command=self.on_slider
        )
        self.slider.pack(fill="x")

        # Initial draw
        self.update_display()

    # --------------------------------------------------------
    # WINDOW LIFECYCLE
    # --------------------------------------------------------

    def on_close(self):
        """
        Stop playback and destroy the window.
        """
        self.stop()
        self.win.destroy()

    # --------------------------------------------------------
    # SCALING HELPERS
    # --------------------------------------------------------

    def get_scaled_percent(self, ch, value):
        """
        Returns a 0.0–1.0 position for the given channel/value,
        using the new_limits and reversed channel list.
        """
        if ch not in self.new_limits:
            return 0.0
        n_min, n_max, _, _ = self.new_limits[ch]
        if n_max == n_min:
            return 0.0
        percent = (value - n_min) / (n_max - n_min)
        percent = max(0.0, min(1.0, percent))
        if ch in self.reversed_channels:
            percent = 1.0 - percent
        return percent

    # --------------------------------------------------------
    # DISPLAY UPDATE
    # --------------------------------------------------------

    def update_display(self):
        """
        Redraws all channel bars and updates labels for the current frame.
        Also updates the status label and slider position.
        """
        if not self.frames:
            return

        frame = self.frames[self.current_frame]

        for ch in self.channel_order:
            val_label, canvas = self.channel_rows[ch]
            value = frame.get(ch, 0)
            val_label.config(text=str(value))

            # Clear canvas
            canvas.delete("all")
            canvas.create_rectangle(
                0, 0, self.bar_width, self.bar_height,
                fill="white", outline="black"
            )

            if value != 0:
                p = self.get_scaled_percent(ch, value)
                bar_len = int(self.bar_width * p)
                canvas.create_rectangle(
                    0, 0, bar_len, self.bar_height,
                    fill="#4a90e2", outline=""
                )

        self.lbl_status.config(
            text=f"Frame: {self.current_frame + 1} / {self.num_frames}"
        )

        # Recursion-safe slider update
        self.slider_updating = True
        self.slider.set(self.current_frame)
        self.slider_updating = False

    # --------------------------------------------------------
    # PLAYBACK CONTROL
    # --------------------------------------------------------

    def play(self):
        """
        Starts playback from the current frame.
        """
        if not self.frames:
            return
        self.playing = True
        self.schedule_next_frame()

    def pause(self):
        """
        Pauses playback (does not reset frame index).
        """
        self.playing = False
        if self.after_id is not None:
            self.win.after_cancel(self.after_id)
            self.after_id = None

    def stop(self):
        """
        Stops playback and resets to frame 0.
        """
        self.pause()
        self.current_frame = 0
        self.update_display()

    def step_forward(self):
        """
        Steps forward by one frame (wraps around).
        """
        self.pause()
        if not self.frames:
            return
        self.current_frame = (self.current_frame + 1) % self.num_frames
        self.update_display()

    def step_back(self):
        """
        Steps backward by one frame (wraps around).
        """
        self.pause()
        if not self.frames:
            return
        self.current_frame = (self.current_frame - 1) % self.num_frames
        self.update_display()

    def schedule_next_frame(self):
        """
        Schedules the next frame during playback using the frame's delay.
        """
        if not self.playing or not self.frames:
            return

        self.update_display()
        delay = self.delays[self.current_frame] if self.delays else 200
        self.current_frame = (self.current_frame + 1) % self.num_frames
        self.after_id = self.win.after(delay, self.schedule_next_frame)

    # --------------------------------------------------------
    # SLIDER CALLBACK (RECURSION-SAFE)
    # --------------------------------------------------------

    def on_slider(self, val):
        """
        Called when the user drags the timeline slider.
        Uses a guard flag to avoid recursion when we update
        the slider programmatically from update_display().
        """
        if self.slider_updating:
            # Ignore programmatic updates
            return

        self.pause()
        try:
            idx = int(float(val))
        except:
            idx = 0
        idx = max(0, min(self.num_frames - 1, idx))
        self.current_frame = idx
        self.update_display()

