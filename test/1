class MaestroMergeGUI:
    """
    Main GUI application class.
    Handles:
      - Loading "My" settings file
      - Loading "Friend" settings file
      - Displaying calibration table
      - Displaying sequences with Preview buttons
      - Displaying subroutines
      - Merging selected sequences and subroutines
      - Launching the SequencePreviewWindow
    """

    def __init__(self, root):
        self.root = root
        self.root.title("Maestro Settings Merge Tool")

        # Paths to files
        self.my_file = None
        self.friend_file = None

        # Parsed friend data
        self.friend_sequences = []
        self.friend_subs = []

        # UI state
        self.seq_vars = []
        self.seq_preview_buttons = []
        self.sub_vars = []

        # Calibration state
        self.channel_values = {}
        self.reversed_vars = {}

        # Notebook tabs
        self.notebook = ttk.Notebook(root)
        self.notebook.pack(fill="both", expand=True)

        # Tabs
        self.tab_cal = ttk.Frame(self.notebook)
        self.tab_seq = ttk.Frame(self.notebook)
        self.tab_sub = ttk.Frame(self.notebook)

        self.notebook.add(self.tab_cal, text="Servo Calibration")
        self.notebook.add(self.tab_seq, text="Sequences")
        self.notebook.add(self.tab_sub, text="Subroutines")

        # Top buttons
        top_frame = ttk.Frame(root)
        top_frame.pack(pady=5)

        ttk.Button(top_frame, text="Select My Settings File",
                   command=self.load_my_file).pack(side="left", padx=5)
        ttk.Button(top_frame, text="Select Friend Settings File",
                   command=self.load_friend_file).pack(side="left", padx=5)

        ttk.Button(root, text="Merge Selected Items",
                   command=self.merge_files).pack(pady=10)

        # Build calibration table container
        self.build_calibration_table()

        # Build sequence and subroutine areas
        self.seq_frame = ttk.Frame(self.tab_seq)
        self.seq_frame.pack(fill="both", expand=True, padx=10, pady=10)

        self.sub_frame = ttk.Frame(self.tab_sub)
        self.sub_frame.pack(fill="both", expand=True, padx=10, pady=10)

    # --------------------------------------------------------
    # CALIBRATION TABLE
    # --------------------------------------------------------

    def build_calibration_table(self):
        """
        Creates the scrollable calibration table container.
        """
        container = ttk.Frame(self.tab_cal)
        container.pack(fill="both", expand=True)

        canvas = tk.Canvas(container)
        canvas.pack(side="left", fill="both", expand=True)

        scrollbar = ttk.Scrollbar(container, orient="vertical",
                                  command=canvas.yview)
        scrollbar.pack(side="right", fill="y")

        canvas.configure(yscrollcommand=scrollbar.set)
        canvas.bind("<Configure>",
                    lambda e: canvas.configure(scrollregion=canvas.bbox("all")))

        self.cal_table = ttk.Frame(canvas)
        canvas.create_window((0, 0), window=self.cal_table, anchor="nw")

        # Header row
        headers = ["Channel", "Min", "Max", "Home", "Neutral", "Reversed"]
        for col, text in enumerate(headers):
            ttk.Label(self.cal_table, text=text,
                      font=("Arial", 10, "bold")).grid(
                row=0, column=col, padx=5, pady=5
            )

    def populate_calibration_table(self, channels):
        """
        Populates the calibration table with channel values.
        """
        # Clear old rows
        for widget in self.cal_table.winfo_children():
            if int(widget.grid_info()["row"]) > 0:
                widget.destroy()

        self.channel_values = {}
        self.reversed_vars = {}

        for i, tag in enumerate(channels):
            vals = parse_channel_values(tag)

            self.channel_values[i] = {
                "min": tk.StringVar(value=str(vals["min"])),
                "max": tk.StringVar(value=str(vals["max"])),
                "home": tk.StringVar(value=str(vals["home"])),
                "neutral": tk.StringVar(value=str(vals["neutral"])),
            }

            self.reversed_vars[i] = tk.BooleanVar(value=False)

            ttk.Label(self.cal_table, text=str(i)).grid(
                row=i+1, column=0, padx=5, pady=2
            )

            ttk.Entry(self.cal_table, textvariable=self.channel_values[i]["min"],
                      width=8).grid(row=i+1, column=1)
            ttk.Entry(self.cal_table, textvariable=self.channel_values[i]["max"],
                      width=8).grid(row=i+1, column=2)
            ttk.Entry(self.cal_table, textvariable=self.channel_values[i]["home"],
                      width=8).grid(row=i+1, column=3)
            ttk.Entry(self.cal_table, textvariable=self.channel_values[i]["neutral"],
                      width=8).grid(row=i+1, column=4)

            ttk.Checkbutton(self.cal_table,
                            variable=self.reversed_vars[i]).grid(
                row=i+1, column=5
            )

    # --------------------------------------------------------
    # FILE LOADING
    # --------------------------------------------------------

    def load_my_file(self):
        """
        Loads the user's own Maestro settings file.
        """
        path = filedialog.askopenfilename(title="Select My Settings File")
        if not path:
            return

        self.my_file = path
        text = load_file(path)

        channels = extract_channels(text)
        if not channels:
            messagebox.showerror("Error",
                                 "No <Channel> tags found in your settings file.")
            return

        self.populate_calibration_table(channels)

        messagebox.showinfo("Loaded", f"My settings loaded:\n{path}")

    def load_friend_file(self):
        """
        Loads the friend's Maestro settings file and populates:
          - Sequence list
          - Subroutine list
        """
        path = filedialog.askopenfilename(title="Select Friend Settings File")
        if not path:
            return

        self.friend_file = path
        text = load_file(path)

        # Channel count warning
        my_channels = extract_channels(load_file(self.my_file)) if self.my_file else []
        friend_channels = extract_channels(text)

        if my_channels and friend_channels:
            if len(friend_channels) != len(my_channels):
                messagebox.showwarning(
                    "Channel Count Mismatch",
                    f"Friend file has {len(friend_channels)} channels, "
                    f"but your file has {len(my_channels)}.\n\n"
                    f"Extra or missing channels will be ignored."
                )

        # ---------------- Sequences ----------------
        self.friend_sequences = extract_sequences(text)

        # Clear old sequence UI
        for w in self.seq_frame.winfo_children():
            w.destroy()
        self.seq_vars = []
        self.seq_preview_buttons = []

        if not self.friend_sequences:
            ttk.Label(self.seq_frame, text="No sequences found.").pack(anchor="w")
        else:
            for i, _ in enumerate(self.friend_sequences):
                row = ttk.Frame(self.seq_frame)
                row.pack(fill="x", anchor="w", pady=2)

                var = tk.BooleanVar()
                self.seq_vars.append(var)
                chk = ttk.Checkbutton(row, text=f"Sequence {i}", variable=var)
                chk.pack(side="left")

                # PREVIEW BUTTON
                btn = ttk.Button(row, text="Preview",
                                 command=lambda idx=i: self.open_sequence_preview(idx))
                btn.pack(side="left", padx=5)
                self.seq_preview_buttons.append(btn)

        # ---------------- Subroutines ----------------
        friend_script = extract_script(text)
        self.friend_subs = extract_subroutines(friend_script)

        # Clear old subroutine UI
        for w in self.sub_frame.winfo_children():
            w.destroy()
        self.sub_vars = []

        if not self.friend_subs:
            ttk.Label(self.sub_frame, text="No subroutines found.").pack(anchor="w")
        else:
            for sub in self.friend_subs:
                var = tk.BooleanVar()
                self.sub_vars.append(var)
                ttk.Checkbutton(self.sub_frame, text=sub["name"],
                                variable=var).pack(anchor="w")

        messagebox.showinfo("Loaded", f"Friend settings loaded:\n{path}")

    # --------------------------------------------------------
    # PREVIEW LAUNCHER
    # --------------------------------------------------------

    def build_new_limits_and_reversed(self):
        """
        Builds new_limits dict and reversed_channels list
        from the calibration table.
        """
        new_limits = {}
        reversed_channels = []
        for ch, vals in self.channel_values.items():
            try:
                new_limits[ch] = (
                    int(vals["min"].get()),
                    int(vals["max"].get()),
                    int(vals["home"].get()),
                    int(vals["neutral"].get()),
                )
            except:
                raise ValueError(f"Invalid numeric value in channel {ch}.")
            if self.reversed_vars[ch].get():
                reversed_channels.append(ch)
        return new_limits, reversed_channels

    def open_sequence_preview(self, index):
        """
        Opens the preview window for the selected sequence.
        """
        if not self.friend_sequences:
            return

        seq_text = self.friend_sequences[index]
        frames, delays, channel_order = parse_sequence_frames(seq_text)
        if not frames:
            messagebox.showwarning("Preview", "No frames found in this sequence.")
            return

        try:
            new_limits, reversed_channels = self.build_new_limits_and_reversed()
        except ValueError as e:
            messagebox.showerror("Error", str(e))
            return

        # Filter channel_order to only channels that exist in new_limits
        channel_order = [ch for ch in channel_order if ch in new_limits]
        if not channel_order:
            messagebox.showwarning("Preview", "No valid channels for preview.")
            return

        SequencePreviewWindow(
            self.root,
            seq_name=f"Sequence {index}",
            frames=frames,
            delays=delays,
            channel_order=channel_order,
            new_limits=new_limits,
            reversed_channels=reversed_channels
        )

    # --------------------------------------------------------
    # SUBROUTINE CONFLICT DIALOG
    # --------------------------------------------------------

    def ask_sub_conflict(self, name):
        """
        Asks the user how to resolve a subroutine name conflict.
        Returns (action, new_name).
        """
        dlg = tk.Toplevel(self.root)
        dlg.title("Subroutine Conflict")
        dlg.grab_set()

        ttk.Label(
            dlg,
            text=f"Subroutine '{name}' already exists.\nWhat would you like to do?"
        ).pack(padx=10, pady=10)

        result = {"action": "skip", "name": None}

        def do_skip():
            result["action"] = "skip"
            dlg.destroy()

        def do_overwrite():
            result["action"] = "overwrite"
            dlg.destroy()

        def do_rename():
            new_name = simpledialog.askstring(
                "Rename Subroutine",
                f"Enter new name for '{name}':",
                parent=self.root
            )
            if new_name and new_name.strip():
                result["action"] = "rename"
                result["name"] = new_name.strip()
            dlg.destroy()

        btn_frame = ttk.Frame(dlg)
        btn_frame.pack(pady=10)

        ttk.Button(btn_frame, text="Skip", command=do_skip).pack(side="left", padx=5)
        ttk.Button(btn_frame, text="Overwrite", command=do_overwrite).pack(side="left", padx=5)
        ttk.Button(btn_frame, text="Rename…", command=do_rename).pack(side="left", padx=5)

        dlg.wait_window()
        return result["action"], result["name"]

