# ------------------------------------------------------------
# FILE LOADING
# ------------------------------------------------------------

def load_file(path):
    """
    Loads a text file and normalizes line endings.
    """
    with open(path, "r", encoding="utf-8") as f:
        text = f.read()
    # Normalize CRLF / CR to LF
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    return text

# ------------------------------------------------------------
# CHANNEL PARSING
# ------------------------------------------------------------

def extract_channels(text):
    """
    Extracts all <Channel ...> tags from a Maestro settings file.
    """
    return re.findall(r'<Channel [^>]*>', text)

def parse_channel_values(tag):
    """
    Extracts min/max/home/neutral from a <Channel> tag.
    Returns a dict with integer values.
    """
    return {
        "min": int(re.search(r'min="(\d+)"', tag).group(1)),
        "max": int(re.search(r'max="(\d+)"', tag).group(1)),
        "home": int(re.search(r'home="(\d+)"', tag).group(1)),
        "neutral": int(re.search(r'neutral="(\d+)"', tag).group(1)),
    }

# ------------------------------------------------------------
# SEQUENCE EXTRACTION
# ------------------------------------------------------------

def extract_sequences(text):
    """
    Extracts all <Sequence>...</Sequence> blocks.
    """
    return re.findall(r'<Sequence.*?</Sequence>', text, re.DOTALL)

# ------------------------------------------------------------
# SCRIPT + SUBROUTINE EXTRACTION
# ------------------------------------------------------------

def extract_script(text):
    """
    Extracts the <Script>...</Script> block.
    If none exists, returns the entire text as script.
    """
    m = re.search(r"<Script[^>]*>(.*?)</Script>", text, re.DOTALL)
    if m:
        return m.group(1).strip()
    else:
        return text.strip()

def extract_subroutines(script_text):
    """
    Extracts all subroutines of the form:
        sub name
            ...
    Returns a list of dicts: { "name": ..., "text": ... }
    """
    subs = []
    pattern = r'(?s)\bsub\s+([A-Za-z_][A-Za-z0-9_]*)\b(.*?)(?=\bsub\b|\Z)'
    for m in re.finditer(pattern, script_text):
        name = m.group(1)
        body = m.group(2)
        full = f"sub {name}{body}"
        subs.append({"name": name, "text": full.strip()})
    return subs

def remove_sub_by_name(script_text, name):
    """
    Removes a subroutine by name from the script text.
    """
    pattern = r'(?s)\bsub\s+' + re.escape(name) + r'\b.*?(?=\bsub\b|\Z)'
    return re.sub(pattern, "", script_text).strip()

# ------------------------------------------------------------
# VALUE SCALING HELPERS
# ------------------------------------------------------------

def scale_value(val, old_min, old_max, new_min, new_max, reversed=False):
    """
    Scales a servo value from old range to new range.
    Applies reversal if needed.
    """
    if val == 0:
        return 0
    percent = (val - old_min) / (old_max - old_min) if old_max != old_min else 0
    percent = max(0, min(1, percent))
    if reversed:
        return int(new_max - percent * (new_max - new_min))
    return int(new_min + percent * (new_max - new_min))

def scale_sequence(seq_text, old_limits, new_limits, reversed_channels):
    """
    Scales all <Frame> values inside a <Sequence> block.
    """
    def repl(match):
        tag = match.group(1)
        vals = match.group(2).split()
        new_vals = []
        for i, v in enumerate(vals):
            try:
                v_int = int(v)
                if i in old_limits and i in new_limits:
                    o_min, o_max = old_limits[i]
                    n_min, n_max, _, _ = new_limits[i]
                    new_vals.append(str(scale_value(
                        v_int, o_min, o_max, n_min, n_max, i in reversed_channels
                    )))
                else:
                    new_vals.append(v)
            except:
                new_vals.append(v)
        return f"{tag}{' '.join(new_vals)}"

    return re.sub(r'(<Frame[^>]*>)([^<]+)', repl, seq_text)

